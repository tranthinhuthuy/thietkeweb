<!DOCTYPE html>

<html lang="vi">

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Quản lý tài khoản hệ thống</title>

<link
rel="stylesheet"
href="admin.css">

<link
rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<script
src="js/accounts.js" defer></script>

</head>

<body>

<!-- HEADER -->

<header class="admin-header">

<h1>

<i class="fa-solid fa-users-gear"></i>

QUẢN LÝ TÀI KHOẢN HỆ THỐNG

</h1>

<div class="admin-actions">

<button
type="button"
onclick="window.location.href='admin.html'">

<i class="fa-solid fa-house"></i>

Dashboard

</button>

</div>

</header>

<!-- NỘI DUNG -->

<div class="main-content">

<!-- THỐNG KÊ -->

<section>

<h2 class="section-title">

Thống kê tài khoản

</h2>

<div class="dashboard">

<div class="card">

<h3>Tổng tài khoản</h3>

<span id="totalUsers">
0
</span>

</div>

<div class="card">

<h3>Quản trị viên</h3>

<span id="totalAdmins">
0
</span>

</div>

<div class="card">

<h3>Người dùng</h3>

<span id="totalMembers">
0
</span>

</div>

</div>

</section>

<!-- QUẢN LÝ TÀI KHOẢN -->

<section>

<h2 class="section-title">

Quản lý tài khoản

</h2>

<div class="account-toolbar">

<button
type="button"
class="add-user-btn"
onclick="openUserModal()">

<i class="fa-solid fa-user-plus"></i>

Thêm tài khoản

</button>

<div class="search-container">

<input
type="text"
id="searchUser"
placeholder="Tìm theo họ tên, tài khoản, email...">

<button
type="button"
onclick="searchUser()">

<i class="fa-solid fa-magnifying-glass"></i>

</button>

</div>

</div>

<p
id="searchMessage"
class="search-message">

</p>

<div class="table-wrapper">

<table>

<thead>

<tr>

<th>Họ tên</th>

<th>Tài khoản</th>

<th>Email</th>

<th>SĐT</th>

<th>Vai trò</th>

<th>Thao tác</th>

</tr>

</thead>

<tbody id="userTable">

<tr>

<td
colspan="6"
class="not-found">

Chưa có tài khoản nào

</td>

</tr>

</tbody>

</table>

</div>

</section>

</div>

<!-- POPUP THÊM / SỬA -->

<div
id="userModal"
class="modal">

    <div class="modal-content">

        <span
        class="close"
        onclick="closeUserModal()">

            ×

        </span>

        <h2 id="modalTitle">

            Thêm tài khoản mới

        </h2>

        <input
        type="hidden"
        id="editIndex">

        <div class="form-grid">

            <div>

                <label>

                    Họ và tên <span>*</span>

                </label>

                <input
                type="text"
                id="fullName"
                placeholder="Nhập họ và tên">

            </div>

            <div>

                <label>

                    Tên đăng nhập <span>*</span>

                </label>

                <input
                type="text"
                id="username"
                placeholder="Nhập tên đăng nhập">

            </div>

            <div>

                <label>

                    Email

                </label>

                <input
                type="email"
                id="email"
                placeholder="Nhập email">

            </div>

            <div>

                <label>

                    Số điện thoại

                </label>

                <input
                type="text"
                id="phone"
                placeholder="Nhập số điện thoại">

            </div>

            <div>

                <label>

                    Mật khẩu <span>*</span>

                </label>

                <input
                type="password"
                id="password"
                placeholder="Nhập mật khẩu">

            </div>

            <div>

                <label>

                    Vai trò <span>*</span>

                </label>

                <select id="role">

                    <option value="user">

                        Người dùng

                    </option>

                    <option value="admin">

                        Quản trị viên

                    </option>

                </select>

            </div>

        </div>

        <div class="modal-actions">

            <button
            type="button"
            class="save-btn"
            onclick="saveUser()">

                <i class="fa-solid fa-floppy-disk"></i>

                Lưu tài khoản

            </button>

            <button
            type="button"
            class="cancel-btn"
            onclick="closeUserModal()">

                <i class="fa-solid fa-xmark"></i>

                Hủy

            </button>

        </div>

    </div>

</div>


<!-- FOOTER -->

<footer class="footer">

<h3>

HỆ THỐNG QUẢN TRỊ TÀI KHOẢN

</h3>

<p>

Trung tâm Phục vụ Hành chính công xã Đăk Hà

</p>

</footer>

</body>

</html>
